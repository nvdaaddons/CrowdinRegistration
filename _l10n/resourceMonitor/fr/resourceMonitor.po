#: addon/globalPlugins/resourceMonitor/__init__.py:46
msgid "No authentication (Open)"
msgstr "Pas d'authentification (ouvert)"

#: addon/globalPlugins/resourceMonitor/__init__.py:71
msgid "Connected to {}"
msgstr "Connecté à {}"

#: addon/globalPlugins/resourceMonitor/__init__.py:81
msgid "Disconnected from {}"
msgstr "Déconnecté de {}"

#: addon/globalPlugins/resourceMonitor/__init__.py:86
msgid "A wireless device has been enabled"
msgstr "Un appareil sans fil a été activé"

#: addon/globalPlugins/resourceMonitor/__init__.py:92
msgid "A wireless device has been disabled"
msgstr "Un appareil sans fil a été désactivé"

#. Translators: Message reported when there is no battery on the system,
#. mostly laptops with battery pack removed and running on AC power.
#: addon/globalPlugins/resourceMonitor/__init__.py:215
msgid "This computer does not have a battery connected."
msgstr "Cet ordinateur n'a pas de battrie."

#. Translators: message presented when AC is connected and battery is charging,
#. also show current battery percentage.
#: addon/globalPlugins/resourceMonitor/__init__.py:221
#, python-brace-format
msgid "{percent}%, battery charging."
msgstr "Batterie en charge, {percent}%."

#. Translators: message presented when computer is running on battery power,
#. showing percentage remaining yet battery time is unknown.
#: addon/globalPlugins/resourceMonitor/__init__.py:227
#, python-brace-format
msgid "{percent}% battery remaining, battery time unknown."
msgstr "Niveau de batterie {percent}%, temps restant inconnu."

#. Translators: battery and system uptime in hours.
#. Translators: system uptime in hours.
#: addon/globalPlugins/resourceMonitor/__init__.py:241
#: addon/globalPlugins/resourceMonitor/__init__.py:506
#, python-brace-format
msgid "{hours:d} hour"
msgid_plural "{hours:d} hours"
msgstr[0] "{hours:d} heure"
msgstr[1] "{hours:d} heures"

#. Translators: battery and system uptime in minutes.
#. Translators: system uptime in minutes.
#: addon/globalPlugins/resourceMonitor/__init__.py:246
#: addon/globalPlugins/resourceMonitor/__init__.py:510
#, python-brace-format
msgid "{minutes:d} minute"
msgid_plural "{minutes:d} minutes"
msgstr[0] ""
msgstr[1] ""

#. Translators: message presented when computer is running on battery power,
#. showing percentage remaining and estimated remaining time.
#: addon/globalPlugins/resourceMonitor/__init__.py:254
#, python-brace-format
msgid "{percent}% battery remaining, about {time}."
msgstr "Niveau de batterie {percent}%, environ {time}."

#. Translators: Message reported when battery level is low.
#: addon/globalPlugins/resourceMonitor/__init__.py:258
msgid " Warning: low battery."
msgstr " Alerte : batterie faible."

#. Translators: Message reported when battery level is critical.
#: addon/globalPlugins/resourceMonitor/__init__.py:261
msgid " Warning: critically low battery."
msgstr " Alerte : niveau de batterie critique."

#. Translators: Presents Windows version (example output: "Windows 10 22H2 (AMD64) build 19045.5247").
#: addon/globalPlugins/resourceMonitor/__init__.py:282
#, python-brace-format
msgid "{winVersion} ({cpuBit}) build {build}"
msgstr ""

#. Translators: The gestures category for this add-on in input gestures dialog (2013.3 or later).
#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: addon/globalPlugins/resourceMonitor/__init__.py:290 buildVars.py:21
msgid "Resource Monitor"
msgstr ""

#. Translators: Input help message about battery info command in Resource Monitor.
#: addon/globalPlugins/resourceMonitor/__init__.py:321
msgid "Presents battery percentage, charging status, remaining time (if not charging), and a warning if the battery is low or critical."
msgstr "Présente le pourcentage de chargement de la batterie, si elle est en charge, le temps restant (sauf si en charge), et une alerte si le niveau de la batterie est faible ou critique."

#: addon/globalPlugins/resourceMonitor/__init__.py:337
msgid "Presents the used and total space of the static and removable drives on this computer."
msgstr "Présente l'espace total et l'espace utilisé des disques locaux et amovibles de cet ordinateur."

#. Translators: Shows drive letter, type of drive (fixed or removable),
#. used capacity and total capacity of a drive
#. (example: C drive, ntfs; 40 GB of 100 GB used (40%).
#: addon/globalPlugins/resourceMonitor/__init__.py:356
#, python-brace-format
msgid "{driveName} ({driveType} drive): {usedSpace} of {totalSpace} used {percent}%."
msgstr "{driveName} (disque {driveType}) : {usedSpace} utilisé sur {totalSpace} {percent}%."

#. Translators: Input help mode message about processor info command in Resource Monitor.
#: addon/globalPlugins/resourceMonitor/__init__.py:371
msgid "Presents the average processor load and the load of each core."
msgstr "Présente la charge moyenne du processeur et la charge de chaque coeur."

#. Translators: Shows average load of CPU cores (example: core 1, 50%).
#: addon/globalPlugins/resourceMonitor/__init__.py:381
#, python-brace-format
msgid "Core {coreNumber}: {corePercent}%"
msgstr "Coeur {coreNumber}: {corePercent}%"

#. Translators: Shows average load of the processor on single-core systems.
#: addon/globalPlugins/resourceMonitor/__init__.py:388
#, python-brace-format
msgid "Average CPU load {avgLoad}%."
msgstr "Charge moyenne du processeur {avgLoad}%."

#. Translators: Shows average load of the processor and the load for each core on multi-core systems.
#: addon/globalPlugins/resourceMonitor/__init__.py:391
#, python-brace-format
msgid "Average CPU load {avgLoad}%, {cores}."
msgstr "Charge moyenne du processeur {avgLoad}%, {cores}."

#. Translators: Input help mode message about memory info command in Resource Monitor.
#: addon/globalPlugins/resourceMonitor/__init__.py:401
msgid "Presents the used and total space for both physical and virtual ram."
msgstr "Présente les quantités de mémoire physique et virtuelle totales et utilisées."

#. Translators: Shows RAM (physical memory) usage.
#: addon/globalPlugins/resourceMonitor/__init__.py:409
#, python-brace-format
msgid "Physical: {physicalUsed} of {physicalTotal} used ({physicalPercent}%). "
msgstr "Mémoire physique : {physicalUsed} utilisé sur {physicalTotal} ({physicalPercent}%). "

#. Translators: Shows virtual memory usage.
#: addon/globalPlugins/resourceMonitor/__init__.py:417
#, python-brace-format
msgid "Virtual: {virtualUsed} of {virtualTotal} used ({virtualPercent}%)."
msgstr "Mémoire virtuelle : {virtualUsed} utilisé sur {virtualTotal} ({virtualPercent}%)."

#. Translators: Input help mode message about Windows version command in Resource Monitor.
#: addon/globalPlugins/resourceMonitor/__init__.py:429
msgid "Announces the version of Windows you are using."
msgstr "Annonce la version de Windows que vous utilisez."

#. Translators: Input help mode message about obtaining the ssid of the wireless network,
#. and the strength of the network.
#: addon/globalPlugins/resourceMonitor/__init__.py:444
msgid "Announces the system's wireless network ssid name, and its strength."
msgstr "Annonce le nom SSID du réseau sans fil du système et sa force."

#: addon/globalPlugins/resourceMonitor/__init__.py:457
#: addon/globalPlugins/resourceMonitor/__init__.py:464
msgid "No wireless devices"
msgstr "Pas d'appareils sans fil"

#: addon/globalPlugins/resourceMonitor/__init__.py:468
msgid "No wireless connections"
msgstr "Pas de connexions sans fil"

#: addon/globalPlugins/resourceMonitor/__init__.py:481
msgid "Connected wireless network: {}. Signal strength: {}%. Security type: {}"
msgstr "Réseau sans fil connecté : {}. Force du signal : {}%. Type de sécurité : {}"

#. Translators: system uptime in days.
#: addon/globalPlugins/resourceMonitor/__init__.py:502
#, python-brace-format
msgid "{days:d} day"
msgid_plural "{days:d} days"
msgstr[0] "{days:d} jour"
msgstr[1] "{days:d} jours"

#. Translators: system uptime in seconds.
#: addon/globalPlugins/resourceMonitor/__init__.py:514
#, python-brace-format
msgid "{seconds:d} second"
msgid_plural "{seconds:d} seconds"
msgstr[0] "{seconds:d} seconde"
msgstr[1] "{seconds:d} secondes"

#. Translators: Input help mode message about obtaining the system's uptime
#: addon/globalPlugins/resourceMonitor/__init__.py:520
msgid "Announces the system's uptime."
msgstr "Annonce le temps de bon fonctionnement du système."

#. Translators: Obtaining uptime failed
#: addon/globalPlugins/resourceMonitor/__init__.py:533
msgid "Failed to get the system's uptime."
msgstr "Impossible d'obtenir le temps de fonctionnement du système."

#. Translators: Input help mode message about overall system resource info command in Resource Monitor
#: addon/globalPlugins/resourceMonitor/__init__.py:537
msgid "Presents used ram, average processor load, and battery info if available."
msgstr "Présente la quantité de mémoire utilisée, la charge moyenne du processeur, et les informations sur la batterie si disponibles."

#: addon/globalPlugins/resourceMonitor/__init__.py:545
#, python-brace-format
msgid "{ramPercent}% RAM used, CPU at {cpuPercent}%."
msgstr "{ramPercent}% RAM utilisée, CPU à {cpuPercent}%."

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "A handy resource monitor to report CPU load, memory usage, battery, disk usage status and more."
msgstr "Un superviseur de resources clés en mains pour rapporter la charge moyenne du processeur, l'utilisation de la mémoire, l'état d'utilisation des disques et de la batterie ainsi que d'autres informations."

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid "* NVDA 2025.3.2 or later is required.\n"
"* NVDA will announce Windows Server releases using standardized release name instead of dedicated server release name e.g. Windows Server 24H2 instead of Windows Server 2025.\n"
"* NVDA will no longer add \"0 minutes\" to battery status (example: 4 hours instead of 4 hours, 0 minutes).\n"
"* NVDA will recognize additional prefixes for larger memory and storage sizes including ronnabyte (1000 to the power of 9) and quettabyte (1000 to the power of 10)."
msgstr ""

