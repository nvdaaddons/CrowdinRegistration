#. Translators: The description of a command of this add-on.
#: addon/globalPlugins/ndtt/__init__.py:134
#, python-brace-format
msgid "Opens {name} settings"
msgstr "Відкрити налаштування {name}"

#. Translators: Reported when pressing a quick navigation command in the log.
#: addon/globalPlugins/ndtt/logReader.py:611
msgid "No more item"
msgstr "Більше немає елемента"

#. Translators: Reported when pressing a quick navigation command in the log.
#: addon/globalPlugins/ndtt/logReader.py:663
msgid "No more block"
msgstr "Більше немає блоків"

#. Translators: Reported when pressing a quick navigation command in the log.
#: addon/globalPlugins/ndtt/logReader.py:680
msgid "No block here"
msgstr "Тут немає блоку"

#. Translators: Reported when pressing the Go to error command in the log
#: addon/globalPlugins/ndtt/logReader.py:702
msgid "No error indicator for this frame"
msgstr "Для цього кадру немає індикатора помилки"

#. Translators: Reported when pressing the go to error command in a traceback line.
#: addon/globalPlugins/ndtt/logReader.py:731
msgid "No traceback here"
msgstr "Тут немає трасування стека"

#. Translators: Input help mode message for log navigation commands. {st} will be replaced by
#. the search type (Io, Debug, Message, etc.
#: addon/globalPlugins/ndtt/logReader.py:748
#, python-brace-format
msgid "Moves to the next logged message of type {st}."
msgstr "Переходить до наступного зареєстрованого повідомлення типу {st}."

#. Translators: Input help mode message for log navigation commands. {st} will be replaced by the
#. search type (Io, Debug, Message, etc.
#: addon/globalPlugins/ndtt/logReader.py:752
#, python-brace-format
msgid "Moves to the previous logged message of type {st}."
msgstr "Переходить до попереднього зареєстрованого повідомлення типу {st}."

#. Translators: A message reported when toggling log reader commands.
#: addon/globalPlugins/ndtt/logReader.py:837
msgid "Log Reader commands enabled."
msgstr "Команди читання журналу увімкнено."

#. Translators: A message reported when toggling log reader commands.
#: addon/globalPlugins/ndtt/logReader.py:840
msgid "Log Reader commands disabled."
msgstr "Команди читання журналу вимкнено."

#. Translators: Input help mode message for Toggle log translation script.
#: addon/globalPlugins/ndtt/logReader.py:845
msgid "Toggles speech translation in the log"
msgstr "Перемкнути переклад мовлення в журналі"

#. Translators: A message reported when disabling log translation.
#: addon/globalPlugins/ndtt/logReader.py:852
msgid "Log translation disabled"
msgstr "Переклад журналу вимкнено"

#. Translators: A message reported when enabling log translation.
#: addon/globalPlugins/ndtt/logReader.py:857
msgid "Log translation enabled"
msgstr "Переклад журналу увімкнено"

#. Translators: A message reported when trying to enable log translation.
#: addon/globalPlugins/ndtt/logReader.py:860
msgid "Cannot enable log translation. Please install or enable Instant Translate add-on."
msgstr "Не вдається увімкнути переклад журналу.  Будь ласка, установіть або увімкнить доповнення Instant Translate."

#. Translators: Input help mode message for Open source file script.
#: addon/globalPlugins/ndtt/logReader.py:864
msgid "Opens the source code file whose path is located at the caret's position."
msgstr "Відкриває файл вихідного коду, шлях до якого знаходиться у позиції каретки."

#. Translators: A message reported when trying to open the source code from the current line.
#: addon/globalPlugins/ndtt/logReader.py:884
msgid "No file path or object found on this line."
msgstr "У цьому рядку не знайдено шлях до файлу або об'єкта."

#. Translators: Input help mode message for go to error script.
#: addon/globalPlugins/ndtt/logReader.py:890
msgid "Move the caret at the error's position in a traceback frame. A second press selects the erroneous code. A third press selects the error with its context."
msgstr "Переміщує курсор у позицію помилки в кадрі трасування. Друге натиснення виділяє помилковий код. Третє — виділяє помилку разом із контекстом."

#. Translators: A message reported when using block navigation command
#: addon/globalPlugins/ndtt/logReader.py:917
#: addon/globalPlugins/ndtt/logReader.py:947
msgid "Not in a log message"
msgstr "Немає в повідомленні журналу"

#. Translators: A message reported when using block navigation command
#: addon/globalPlugins/ndtt/logReader.py:922
#: addon/globalPlugins/ndtt/logReader.py:952
msgid "No block in this message"
msgstr "У цьому повідомленні немає блоку"

#. Translators: Input help mode message for Log Reader help script.
#: addon/globalPlugins/ndtt/logReader.py:974
msgid "Displays help for the Log reader commands"
msgstr "Відображає довідку для команд читання журналу"

#. Translators: Title of the Log Reader commands help window.
#: addon/globalPlugins/ndtt/logReader.py:979
#, python-brace-format
msgid "Log Reader commands ({name})"
msgstr "Команди читання журналу {name}"

#. Translators: Input help mode message for Add marker in log script.
#: addon/globalPlugins/ndtt/logReader.py:1093
msgid "Adds a marker in the log."
msgstr "Додає маркер у журналі."

#. Translators: a message telling the user that a marker has been inserted in the log.
#: addon/globalPlugins/ndtt/logReader.py:1100
msgid "Marker {} added in the log"
msgstr "Маркер {} додано до журналу"

#. Translators: Input help mode message for Toggle log Reader script.
#: addon/globalPlugins/ndtt/logReader.py:1105
msgid "Activates or deactivates the log Reader commands."
msgstr "Активує або деактивує команди читання журналу."

#. Translators: A message when using Toggle log Reader script.
#: addon/globalPlugins/ndtt/logReader.py:1120
msgid "Not in a text area."
msgstr "Не в текстовій області."

#. Translators: This is a label of an item for the backup combo box in the NDTT Settings panel.
#: addon/globalPlugins/ndtt/ndttGui.py:31
msgid "Off"
msgstr "Вимкнено"

#. Translators: This is a label of an item for the backup combo box in the NDTT Settings panel.
#: addon/globalPlugins/ndtt/ndttGui.py:33
msgid "On"
msgstr "Увімкнено"

#. Translators: A message presented in the settings panel when opened while no-default profile is active.
#: addon/globalPlugins/ndtt/ndttGui.py:38
#, python-brace-format
msgid "{name} add-on can only be configured from the Normal Configuration profile.\n"
"Please close this dialog, set your config profile to default and try again."
msgstr "Додаток {name} можна налаштувати лише з профілю нормальної конфігурації.\n"
"Будь ласка, закрийте цей діалог, установіть початковий профіль конфігурації і повторіть спробу."

#. Translators: This is a label for an edit field in the NDTT Settings panel.
#: addon/globalPlugins/ndtt/ndttGui.py:53
#, python-brace-format
msgid "Command to open a file in your favorite editor\n"
"(use \"{path}\" and \"{line}\" placeholders in this command)"
msgstr "Команда для відкриття файлу у вашому улюбленому редакторі\n"
"(використовуйте заповнювачі \"{path}\" і \"{line}\" у цій команді)"

#. Translators: This is a label for an edit field in the NDTT Settings panel.
#: addon/globalPlugins/ndtt/ndttGui.py:60
msgid "NVDA source code path"
msgstr "Шлях вихідного коду NVDA"

#. Translators: The label of a button to browse for a directory or a file.
#: addon/globalPlugins/ndtt/ndttGui.py:66
#: addon/globalPlugins/ndtt/restartWithOptions.py:229
#: addon/globalPlugins/ndtt/restartWithOptions.py:258
msgid "Browse..."
msgstr "Огляд..."

#. Translators: The title of the dialog presented when browsing for the directory.
#: addon/globalPlugins/ndtt/ndttGui.py:68
#: addon/globalPlugins/ndtt/restartWithOptions.py:260
msgid "Select a directory"
msgstr "Виберіть каталог"

#. Translators: This is a label for the combo box in the NDTT Settings panel.
#: addon/globalPlugins/ndtt/ndttGui.py:75
msgid "Backup of old logs:"
msgstr "Резервне копіювання старих журналів:"

#. Translators: This is a label for a setting in the settings panel
#: addon/globalPlugins/ndtt/ndttGui.py:91
msgid "Limit the number of backups to:"
msgstr "Обмежте кількість резервних копій до:"

#. Translators: This is a label for a setting in the settings panel
#: addon/globalPlugins/ndtt/ndttGui.py:102
msgid "Copy reverse &translation to clipboard"
msgstr "Копіювати зворотний &переклад у буфер обміну"

#. Translators: This is a label for a setting in the settings panel
#: addon/globalPlugins/ndtt/ndttGui.py:114
msgid "Preserve console input history after restart"
msgstr "Зберігати історію введення консолі після перезапуску"

#. Translators: This is a label for a setting in the settings panel
#: addon/globalPlugins/ndtt/ndttGui.py:125
msgid "Number of inputs preserved in Python console history"
msgstr "Кількість введень, що зберігаються в історії консолі Python"

#. Translators: Input help mode message for a toggle command.
#: addon/globalPlugins/ndtt/beepError.py:96
msgid "Toggles play a sound for logged error."
msgstr "Перемикає відтворення звуку для зареєстрованої помилки."

#. Translators: Message reported when calling the command to toggle play a sound for logged errors
#: addon/globalPlugins/ndtt/beepError.py:103
msgid "Yes"
msgstr "Так"

#. Translators: Message reported when calling the command to toggle play a sound for logged errors
#: addon/globalPlugins/ndtt/beepError.py:107
msgid "Only in NVDA test versions"
msgstr "Тільки в тестових версіях NVDA"

#. Translators: Input help mode message for a command.
#: addon/globalPlugins/ndtt/beepError.py:112
msgid "Report the last error logged. A second press clears the memorized last error."
msgstr "Повідомляє про останню зареєстровану помилку. Повторне натискання видаляє останню запам’ятовану помилку."

#. Translators: Message reported when calling the "report last error" command
#: addon/globalPlugins/ndtt/beepError.py:123
msgid "No error"
msgstr "Немає помилок"

#. Translators: Message reported when calling the "report last error" command
#: addon/globalPlugins/ndtt/beepError.py:127
msgid "Last error cleared"
msgstr "Останню помилку видалено"

#. Translators: Part of the description for the layered command script.
#: addon/globalPlugins/ndtt/layeredGestures.py:86
#, python-brace-format
msgid "Entry point for {name} layered commands"
msgstr "Точка входу для {name} багаторівневих команд"

#. Translators: The description of a command of this add-on.
#: addon/globalPlugins/ndtt/layeredGestures.py:105
#, python-brace-format
msgid "Displays help on {name} layered commands"
msgstr "Відображає довідку для багато рівневих команд {name}"

#. Translators: Title of the layered command help window.
#: addon/globalPlugins/ndtt/layeredGestures.py:109
#, python-brace-format
msgid "{name} layered commands"
msgstr "Багато рівневі команди {name}"

#. Translators: Separator between key names in the layered command help window.
#: addon/globalPlugins/ndtt/layeredGestures.py:115
msgid ", "
msgstr ", "

#. Translators: Input help mode message for a command of the object property explorer.
#: addon/globalPlugins/ndtt/objPropExplorer.py:107
msgid "Reports the currently selected property of the object property explorer for the navigator object."
msgstr "Оголошує поточну вибрану властивість Дослідника властивостей об'єкта для об'єкта навігатора."

#. Translators: Input help mode message for a command of the object property explorer.
#: addon/globalPlugins/ndtt/objPropExplorer.py:118
msgid "Displays the currently selected property of the object property explorer for the navigator object in a browseable message."
msgstr "Відображає поточну вибрану властивість Дослідника властивостей об'єкта для об'єкта навігатора у вигляді повідомлення з можливістю перегляду."

#. Translators: Input help mode message for a command of the object property explorer.
#: addon/globalPlugins/ndtt/objPropExplorer.py:129
msgid "Selects the next property of the object property explorer and reports it for the navigator object."
msgstr "Вибирає наступну властивість провідника властивостей об’єкта та повідомляє її для об’єкта навігатора."

#. Translators: Input help mode message for a command of the object property explorer.
#: addon/globalPlugins/ndtt/objPropExplorer.py:141
msgid "Selects the previous property of the object property explorer and reports it for the navigator object."
msgstr "Вибирає попередню властивість провідника властивостей об’єкта та повідомляє її для об’єкта навігатора."

#. Translators: Input help mode message for a command of the object property explorer.
#: addon/globalPlugins/ndtt/objPropExplorer.py:169
msgid "Toggles custom reporting of objects using the Object explorer's selected property when you use object navigation commands."
msgstr "Перемикає повідомлення про власні об'єкти із використанням вибраної властивості Дослідника об'єктів під час використання команд об’єктної навігації."

#. Translators: Message reported by a command of the object property explorer.
#: addon/globalPlugins/ndtt/objPropExplorer.py:178
msgid "Custom object reporting enabled"
msgstr "Промовляння власних об’єктів увімкнено"

#. Translators: Message reported by a command of the object property explorer.
#: addon/globalPlugins/ndtt/objPropExplorer.py:182
msgid "Custom object reporting disabled"
msgstr "Промовляння власних об’єктів вимкнено"

#. Translators: The name of a category in the Input gesture dialog
#: addon/globalPlugins/ndtt/extScriptDesc.py:19
msgid "Scripts without description (modify at your own risk!)"
msgstr "Скрипти без опису (змінюйте на свій страх і ризик!)"

#. Translators: Input help mode message for a toggle command.
#: addon/globalPlugins/ndtt/extScriptDesc.py:66
msgid "Toggles the extended script description mode."
msgstr "Перемикає режим розширеного опису скриптів."

#. Translators: A message reported when toggling Extended script description mode.
#: addon/globalPlugins/ndtt/extScriptDesc.py:77
msgid "Extended script description mode enabled"
msgstr "Режим розширеного опису скриптів увімкнено"

#. Translators: A message reported when toggling Extended script description mode.
#: addon/globalPlugins/ndtt/extScriptDesc.py:81
msgid "Extended script description mode disabled"
msgstr "Режим розширеного опису скриптів вимкнено"

#. Translators: Input help mode message for a toggle command.
#: addon/globalPlugins/ndtt/stackTracing.py:52
msgid "Toggles the stack trace log when the speech function is called."
msgstr "Перемикає журнал трасування стека під час виклику мовної функції."

#. Translators: Reported when toggling the stack trace log feature.
#: addon/globalPlugins/ndtt/stackTracing.py:60
msgid "Stacktrace log enabled"
msgstr "Журнал стека ввімкнено"

#. Translators: Reported when toggling the stack trace log feature.
#: addon/globalPlugins/ndtt/stackTracing.py:63
msgid "Stacktrace log disabled"
msgstr "Журнал стека вимкнено"

#. Translators: Text appearing in the date column of the log manager when the date cnanot be determined.
#: addon/globalPlugins/ndtt/logManagement.py:300
msgid "Unknown"
msgstr "Невідомо"

#. Translators: The title of the Logs Manager Dialog
#: addon/globalPlugins/ndtt/logManagement.py:337
msgid "Logs Manager"
msgstr "Менеджер журналів"

#. Translators: the label for the text on top of the logs manager window.
#: addon/globalPlugins/ndtt/logManagement.py:347
#, python-brace-format
msgid "Logs in {folder}"
msgstr "Журнали в {folder}"

#. Translators: The label for a column in logs list
#: addon/globalPlugins/ndtt/logManagement.py:363
msgid "Date"
msgstr "Дата"

#. Translators: The label for a column in logs list
#: addon/globalPlugins/ndtt/logManagement.py:365
msgid "Type"
msgstr "Тип"

#. Translators: The label for a column in logs list
#: addon/globalPlugins/ndtt/logManagement.py:367
msgid "File name"
msgstr "Ім'я файлу"

#. Translators: The label for a button in Logs Manager dialog to open the selected logs.
#: addon/globalPlugins/ndtt/logManagement.py:375
msgid "&Open"
msgstr "&Відкрити"

#. Translators: The label for a button in Logs Manager dialog to copy the selected logs.
#: addon/globalPlugins/ndtt/logManagement.py:379
msgid "&Copy files"
msgstr "&Копіювати файли"

#. Translators: The label for a button to delete the selected log(s) in Log Manager dialog.
#: addon/globalPlugins/ndtt/logManagement.py:384
msgid "&Delete"
msgstr "&Видалити"

#. Translators: The label of a button in Logs Manager to open the settings panel.
#: addon/globalPlugins/ndtt/logManagement.py:399
msgid "Settings..."
msgstr "Налаштування..."

#. Translators: The label of a button to close the logs manager dialog.
#: addon/globalPlugins/ndtt/logManagement.py:415
msgid "&Close"
msgstr "&Закрити"

#. We open the message box only if no log can be opened
#. Translators: A message displayed to the user when pressing the Open button in the logs manager dialog
#: addon/globalPlugins/ndtt/logManagement.py:517
msgid "The selected log(s) is (are) not available anymore"
msgstr "Вибраний журнал(s) більше (are)не доступний"

#. Translators: A message displayed to the user when pressing the Delete button in the logs manager dialog
#: addon/globalPlugins/ndtt/logManagement.py:523
#, python-brace-format
msgid "The following files will be removed:\n"
"{logsList}\n\n"
"Would you like to continue?"
msgstr "Наступні файли буде видалено:\n"
"{logsList}\n\n"
"Бажаєте продовжити?"

#. Translators: The title of a dialog displayed to the user when pressing the Delete button in the
#. logs manager dialog
#: addon/globalPlugins/ndtt/logManagement.py:528
msgid "Confirm deletion"
msgstr "Підтвердіть видалення"

#. Translators: Message issued when 5 or more logs could not be deleted.
#: addon/globalPlugins/ndtt/logManagement.py:554
#, python-brace-format
msgid "{nLogs} log files could not be deleted. See NVDA's log for details."
msgstr "Файли журналів {nLogs} не вдалося видалити. Докладні відомості наведено у журналі NVDA."

#. Translators: Message issued when 1 to 4 logs could not be deleted.
#: addon/globalPlugins/ndtt/logManagement.py:559
#, python-brace-format
msgid "The following logs files could not be deleted.\n\n"
"{files}"
msgstr "Наступні файли журналів не вдалося видалити.\n\n"
"{files}"

#. Translators: The title of a dialog displayed to the user when pressing the Delete button in
#. the logs manager dialog
#. Translators: The title of a dialog displayed to the user when copying files in the logs manager dialog
#. fails
#. Translators: Caption of the message box error when calling the anonymization command
#: addon/globalPlugins/ndtt/logManagement.py:562
#: addon/globalPlugins/ndtt/logManagement.py:596
#: addon/globalPlugins/ndtt/logManagement.py:702
msgid "Error"
msgstr "Помилка"

#. Translators: reported when requesting to copy the logs selected in the logs manager dialog.
#: addon/globalPlugins/ndtt/logManagement.py:602
msgid "Log files copied"
msgstr "Файли журналів скопійовано"

#. Translators: reported when requesting to copy the logs selected in the logs manager dialog.
#: addon/globalPlugins/ndtt/logManagement.py:606
msgid "Unable to copy the selected logs; the clipboard is not available."
msgstr "Неможливо скопіювати вибрані журнали; буфер обміну недоступний."

#. Translators: reported when requesting to copy the logs selected in the logs manager dialog.
#: addon/globalPlugins/ndtt/logManagement.py:621
msgid "File copied"
msgstr "Файл скопійовано"

#. Translators: menu item label to open the logs manager dialog.
#: addon/globalPlugins/ndtt/logManagement.py:642
msgid "&Logs manager..."
msgstr "&Менеджер журналів..."

#. Translators: Input help mode message for Copy and anonymize log script.
#: addon/globalPlugins/ndtt/logManagement.py:665
msgid "Copy the selection and anonymize it."
msgstr "Скопіюйте виділення та зробіть його анонімним."

#. Translators: a message reported when calling the anonymization command
#: addon/globalPlugins/ndtt/logManagement.py:682
msgid "No selection"
msgstr "Немає виділення"

#. Translators: message of the message box error when calling the anonymization command
#: addon/globalPlugins/ndtt/logManagement.py:700
msgid "Could not anonymize and copy selection.\n\n"
"{}"
msgstr "Не вдалося анонімізувати та скопіювати виділення.\n\n"
"{}"

#. Translators: a message reported when calling the anonymization command
#: addon/globalPlugins/ndtt/logManagement.py:707
msgid "Selected text anonymized and copied in the clipboard."
msgstr "Виділений текст анонімізовано та скопійовано в буфер обміну."

#. Translators: a message reported when calling the anonymization command
#: addon/globalPlugins/ndtt/logManagement.py:719
msgid "Invalid regular expression in anonymization rules file.\n\n"
"File: {}\n"
"Line: {}\n"
"Pattern: {}\n"
"Error: {}"
msgstr "Недійсний регулярний вираз у файлі правил анонімізації.\n\n"
"Файл: {}\n"
"Рядок: {}\n"
"Шаблон: {}\n"
"Помилка: {}"

#. Translators: A message reported when trying to open a source file.
#: addon/globalPlugins/ndtt/fileOpener.py:60
msgid "No path configured for NVDA sources; please see documentation to configure it."
msgstr "Шлях до джерельних кодів NVDA не налаштовано, будь ласка, зверніться до документації, щоб налаштувати його."

#. Translators: A message reported when trying to open a source file.
#: addon/globalPlugins/ndtt/fileOpener.py:65
msgid "No open file command configured; please see documentation to configure it."
msgstr "Команду відкриття файлу не налаштовано, будь ласка, зверніться до документації, щоб налаштувати її."

#. Translators: A message reported when trying to open a source file.
#: addon/globalPlugins/ndtt/fileOpener.py:71
msgid "Wrong format for the open file command in the configuration; please see documentation to configure it."
msgstr "Неправильний формат команди відкриття файлу в конфігурації; дивіться документацію, щоб налаштувати його."

