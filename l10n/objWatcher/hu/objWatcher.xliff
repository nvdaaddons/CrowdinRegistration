        <note appliesTo="source">line: 12</note>
        <note appliesTo="source">prefix: 2. </note>
      </notes>
      <segment state="initial">
        <source>Watch items of interest within the group chat list in the Unigram or WeChat conversation list. New messages can be automatically reported, and background reporting is supported.</source>
        <target>Watch items of interest within the group chat list in the Unigram or WeChat conversation list. New messages can be automatically reported, and background reporting is supported.</target>
      </segment>
    </unit>
