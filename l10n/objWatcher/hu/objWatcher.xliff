      <segment state="initial">
        <source>Watch subtitles or lyric objects of certain players and enable automatic reporting upon refreshing.</source>
        <target>Watch subtitles or lyric objects of certain players and enable automatic reporting upon refreshing.</target>
      </segment>
    </unit>
