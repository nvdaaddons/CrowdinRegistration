#. Translators: The key ont the right of the "0" key in the alpha-numeric part of the keyboard. Note: In the translated documentation (/website/addons/outlookExtended.xx.po in the screenReaderTranslations repo), do not forget to modify the commands section accordingly.
#: addon\appModules\outlook\__init__.py:58
msgid "-"
msgstr "-"

#. Translators: The key just ont the left of the backspace key. Note: In the translated documentation (/website/addons/outlookExtended.xx.po in the screenReaderTranslations repo), do not forget to modify the commands section accordingly.
#: addon\appModules\outlook\__init__.py:60
msgid "="
msgstr "="

#. Translators: Documentation for mark as read script.
#: addon\appModules\outlook\__init__.py:73
msgid "Mark a message as read"
msgstr "Пометить сообщение как прочитанное"

#. Translators: Documentation for mark as unread script.
#: addon\appModules\outlook\__init__.py:81
msgid "Mark a message as unread"
msgstr "Пометить сообщение как непрочитанное"

#. Translators: To what the mark as read/unread applies to
#: addon\appModules\outlook\__init__.py:97
#, python-format
msgid "Messages group: %s"
msgstr "Группа сообщений: %s"

#. Translators: To what the mark as read/unread applies to
#: addon\appModules\outlook\__init__.py:100
#, python-format
msgid "Messages: %s"
msgstr "Сообщения: %s"

#. Translators: Error when mark as read/unread shortcut is called with no message selected
#: addon\appModules\outlook\__init__.py:103
msgid "No message selected"
msgstr "Нет выделенных сообщений"

#. Translators: To announce the message or group status: unread
#: addon\appModules\outlook\__init__.py:112
msgid "unread"
msgstr "не прочитанно"

#. Translators: To announce the message or group status: read
#: addon\appModules\outlook\__init__.py:115
msgid "read"
msgstr "прочитанно"

#. Supersedes _moveToRow in behaviors.py to disable row navigation because need to be debugged:
#. when pressing Ctrl+Alt+downarrow, the focus moves visually but NVDA takes updated focus only when you press control again.
#. Translators: When trying to move by column in address book (Alt+Ctrl+Up/DownArrow)
#: addon\appModules\outlook\__init__.py:202
msgid "Column navigation not supported in the address book"
msgstr "Навигация по столбцам не поддерживается в адресной книге"

#. Translators: When trying to use Alt+Number shortcut but not in message.
#. Translators: Error when trying to move focus in message body
#: addon\appModules\outlook\__init__.py:255
#: addon\appModules\outlook\__init__.py:319
msgid "Not in a message window"
msgstr "Не в окне сообщения"

#. Translators: When user double press Alt+Number to copy a header's field to clipboard
#: addon\appModules\outlook\__init__.py:277
msgid "Copied to clipboard"
msgstr "Скопировано в буфер обмена"

#. Translators: A checkbox state
#: addon\appModules\outlook\__init__.py:285
msgid "checked"
msgstr ""

#: addon\appModules\outlook\__init__.py:285
msgid "unchecked"
msgstr ""

#. Translators: To report name and value of a heaeder's field
#: addon\appModules\outlook\__init__.py:289
#, python-brace-format
msgid "{name} {value}"
msgstr "{name} {value}"

#. Translators: Documentation for report info bar script.
#: addon\appModules\outlook\__init__.py:296
msgid "Reports the information bar in a message, calendar item or task window. If pressed twice, moves the focus to it. If pressed three times, copies its content to the clipboard."
msgstr "Озвучивает информационную панель в сообщении, событии календаря или окне задачи. Если нажать дважды, переводит в него фокус. Если нажать трижды, копирует их содержимое в буфер обмена."

#. Translators: When the info bar is not present
#: addon\appModules\outlook\__init__.py:303
msgid "No information bar"
msgstr "Нет информационной панели"

#. Translators: Documentation for move to message body script.
#: addon\appModules\outlook\__init__.py:309
msgid "Moves the focus to the message body"
msgstr "Переводит фокус в тело сообщения"

#. Translators: Documentation for Attachments script.
#: addon\appModules\outlook\__init__.py:325
msgid "Reports the number and the names of attachments in a message window. If pressed twice, moves the focus to it."
msgstr "Сообщает число и имена вложений в окне сообщения. Если нажать дважды, переводит к ним фокус."

#: addon\appModules\outlook\__init__.py:474
msgid "Test case path not defined."
msgstr "Тестовый путь не определён."

#: addon\appModules\outlook\__init__.py:497
msgid "Test mode offf"
msgstr "Тестовый режим выключен"

#. Translators: Input help mode message for report a header's field command. in outlook message, calendar item or task window
#: addon\appModules\outlook\__init__.py:504
#, python-format
msgid "Reports the header field %s in a message, calendar item or task window. If pressed twice, moves the focus to this field if possible. If pressed three times, copies its content to the clipboard."
msgstr "Озвучивает поле заголовка  %s в сообщении, событии календаря или окне задачи. Если нажать дважды, переводит в это поле фокус. Если нажать трижды, копирует его содержимое в буфер обмена."

#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on to be shown on installation and add-on information.
#: buildVars.py:17
msgid "Outlook Extended"
msgstr "Расширенный Outlook"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:20
msgid "Extended support and features for Microsoft Outlook:\n"
"- Provide gestures to read and navigate to headers, information bar and attachments in messages, calendar items, tasks.\n"
"- Improve result reading in address book.\n"
"- Vocalize mark as read/unread ctrl+q/ctrl+u commands."
msgstr ""

