    <unit id="2561d3c0-7a0c-46bf-bf9f-3a199967a441">
      <notes>
        <note appliesTo="source">line: 6</note>
      </notes>
      <segment state="initial">
        <source>This add-on allows you to download and install the latest NVDA version of the chosen type without visiting any webpage nor using your web browser.</source>
        <target>This add-on allows you to download and install the latest NVDA version of the chosen type without visiting any webpage nor using your web browser.</target>
      </segment>
    </unit>
    <unit id="b410127a-f32f-4bb3-a0ce-90f6f43851d0">
