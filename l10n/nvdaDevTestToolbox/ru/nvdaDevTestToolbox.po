#. Translators: The description of a command of this add-on.
#: addon\globalPlugins\ndtt\__init__.py:72
msgid "Opens NVDA Dev & Test Toolbox add-on settings"
msgstr ""

#. Translators: Input help mode message for a toggle command.
#: addon\globalPlugins\ndtt\beepError.py:91
msgid "Toggles play a sound for logged error."
msgstr "Переключает воспроизведение звука для зарегистрированной ошибки."

#. Translators: Message reported when calling the command to toggle play a sound for logged errors
#: addon\globalPlugins\ndtt\beepError.py:99
msgid "Yes"
msgstr "Да"

#. Translators: Message reported when calling the command to toggle play a sound for logged errors
#: addon\globalPlugins\ndtt\beepError.py:103
msgid "Only in NVDA test versions"
msgstr "Только в тестовых версиях NVDA"

#. Translators: Input help mode message for a command.
#: addon\globalPlugins\ndtt\beepError.py:108
msgid "Report the last error logged. A second press clears the memorized last error."
msgstr "Сообщает о последней зарегистрированной ошибке. Повторное нажатие удаляет последнюю запомненную ошибку."

#. Translators: Message reported when calling the "report last error" command
#: addon\globalPlugins\ndtt\beepError.py:119
msgid "No error"
msgstr "Ошибки не обнаружены"

#. Translators: Message reported when calling the "report last error" command
#: addon\globalPlugins\ndtt\beepError.py:123
msgid "Last error cleared"
msgstr "Последняя ошибка удалена"

#. Translators: The name of a category in the Input gesture dialog
#: addon\globalPlugins\ndtt\extScriptDesc.py:18
msgid "Scripts without description (modify at your own risk!)"
msgstr "Скрипты без описания (меняйте на свой страх и риск!)"

#. Translators: Input help mode message for a toggle command.
#: addon\globalPlugins\ndtt\extScriptDesc.py:67
msgid "Toggles the extended script description mode."
msgstr "Переключает режим расширенного описания скриптов."

#. Translators: A message reported when toggling Extended script description mode.
#: addon\globalPlugins\ndtt\extScriptDesc.py:79
msgid "Extended script description mode enabled"
msgstr "Режим расширенного описания скриптов включён"

#. Translators: A message reported when toggling Extended script description mode.
#: addon\globalPlugins\ndtt\extScriptDesc.py:83
msgid "Extended script description mode disabled"
msgstr "Режим расширенного описания скриптов выключен"

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:57
msgid "No path configured for NVDA sources; please see documentation to configure it."
msgstr "Для источников NVDA путь не настроен; пожалуйста, обратитесь к документации, чтобы настроить его."

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:62
msgid "No open file command configured; please see documentation to configure it."
msgstr "Не настроена команда открытия файла; пожалуйста, обратитесь к документации, чтобы настроить её."

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:67
msgid "Wrong format for the open file command in the configuration; please see documentation to configure it."
msgstr "Неправильный формат команды открытия файла в конфигурации; обратитесь к документации, чтобы настроить его."

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:72
#, python-brace-format
msgid "Editor not found at {}; please check your configuration."
msgstr "Редактор по адресу {} не найден, пожалуйста, проверьте вашу конфигурацию."

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:77
#, python-brace-format
msgid "Object not found: {}"
msgstr "Объект не найден: {}"

#. Translators: A message reported when trying to open a source file.
#: addon\globalPlugins\ndtt\fileOpener.py:82
#, python-brace-format
msgid "File not found: {}"
msgstr "Файл не найден: {}"

#. Translators: Text appearing in the date column of the log manager when the date cnanot be determined.
#: addon\globalPlugins\ndtt\logManagement.py:241
msgid "Unknown"
msgstr "Неизвестно"

#. Translators: The title of the Logs Manager Dialog
#: addon\globalPlugins\ndtt\logManagement.py:277
msgid "Logs Manager"
msgstr "Диспетчер журналов"

#. Translators: the label for the text on top of the logs manager window.
#: addon\globalPlugins\ndtt\logManagement.py:287
#, python-brace-format
msgid "Logs in {folder}"
msgstr "Журналы в {folder}"

#. Translators: The label for a column in logs list
#: addon\globalPlugins\ndtt\logManagement.py:303
msgid "Date"
msgstr "Дата"

#. Translators: The label for a column in logs list
#: addon\globalPlugins\ndtt\logManagement.py:305
msgid "Type"
msgstr "Тип"

#. Translators: The label for a column in logs list
#: addon\globalPlugins\ndtt\logManagement.py:307
msgid "File name"
msgstr "Имя файла"

#. Translators: The label for a button in Logs Manager dialog to open the selected logs.
#: addon\globalPlugins\ndtt\logManagement.py:315
msgid "&Open"
msgstr "&Открыть"

#. Translators: The label for a button to delete the selected log(s) in Log Manager dialog.
#: addon\globalPlugins\ndtt\logManagement.py:319
msgid "&Delete"
msgstr "&Удалить"

#. Translators: The label of a button in Logs Manager to open the settings panel.
#: addon\globalPlugins\ndtt\logManagement.py:334
msgid "Settings..."
msgstr "Настройки..."

#. Translators: The label of a button to close the logs manager dialog.
#: addon\globalPlugins\ndtt\logManagement.py:350
msgid "&Close"
msgstr "&Закрыть"

#. We open the message box only if no log can be opened
#. Translators: A message displayed to the user when pressing the Open button in the logs manager dialog
#: addon\globalPlugins\ndtt\logManagement.py:439
msgid "The selected log(s) is (are) not available anymore"
msgstr "Выбранные журналы больше недоступны"

#. Translators: A message displayed to the user when pressing the Delete button in the logs manager dialog
#: addon\globalPlugins\ndtt\logManagement.py:445
#, python-brace-format
msgid "The following files will be removed:\n"
"{logsList}\n\n"
"Would you like to continue?"
msgstr "Следующие файлы будут удалены:\n"
"{logsList}\n\n"
"Хотите продолжить?"

#. Translators: The title of a dialog displayed to the user when pressing the Delete button in the logs manager dialog
#: addon\globalPlugins\ndtt\logManagement.py:449
msgid "Confirm deletion"
msgstr "Подтвердите удаление"

#. Translators: Message issued when 5 or more logs could not be deleted.
#: addon\globalPlugins\ndtt\logManagement.py:472
#, python-brace-format
msgid "{nLogs} log files could not be deleted. See NVDA's log for details."
msgstr "Файлы журналов {nLogs} не удалось удалить. Подробные сведения приведены в журнале NVDA."

#. Translators: Message issued when 1 to 4 logs could not be deleted.
#: addon\globalPlugins\ndtt\logManagement.py:475
#, python-brace-format
msgid "The following logs files could not be deleted.\n\n"
"{file}"
msgstr ""

#. Translators: The title of a dialog displayed to the user when pressing the Delete button in the logs manager dialog
#: addon\globalPlugins\ndtt\logManagement.py:477
msgid "Error"
msgstr "Ошибка"

#. Translators: menu item label to open the logs manager dialog.
#: addon\globalPlugins\ndtt\logManagement.py:501
msgid "&Logs manager..."
msgstr "&Диспетчер журналов..."

#. Translators: Reported when pressing a quick navigation command in the log.
#: addon\globalPlugins\ndtt\logReader.py:280
msgid "No more item"
msgstr "Больше нет элементов"

#. Translators: Input help mode message for log navigation commands. {st} will be replaced by the search type (Io, Debug, Message, etc.
#: addon\globalPlugins\ndtt\logReader.py:294
#, python-brace-format
msgid "Moves to the next logged message of type {st}."
msgstr "Переходит к следующему зарегистрированному сообщению типа {st}."

#. Translators: Input help mode message for log navigation commands. {st} will be replaced by the search type (Io, Debug, Message, etc.
#: addon\globalPlugins\ndtt\logReader.py:297
#, python-brace-format
msgid "Moves to the previous logged message of type {st}."
msgstr "Переходит к предыдущему зарегистрированному сообщению типа {st}."

#. Translators: Input help mode message for Toggle log Reader script.
#: addon\globalPlugins\ndtt\logReader.py:362
msgid "Activates or deactivates the log Reader commands."
msgstr "Включает или выключает команды чтения журнала."

#. Translators: A message reported when toggling log reader commands.
#: addon\globalPlugins\ndtt\logReader.py:370
msgid "Log Reader commands enabled."
msgstr "Команды чтения журнала включены."

#. Translators: A message reported when toggling log reader commands.
#: addon\globalPlugins\ndtt\logReader.py:373
msgid "Log Reader commands disabled."
msgstr "Команды чтения журнала выключены."

#. Translators: Input help mode message for Open source file script.
#: addon\globalPlugins\ndtt\logReader.py:378
msgid "Opens the source code file whose path is located at the caret's position."
msgstr "Открывает файл исходного кода, путь к которому находится в позиции каретки."

#. Translators: A message reported when trying to open the source code from the current line.
#: addon\globalPlugins\ndtt\logReader.py:396
msgid "No file path or object found on this line."
msgstr "В этой строке не найден путь к файлу или объекту."

#. Translators: This is a label of an item for the backup combo box in the NDTT Settings panel.
#: addon\globalPlugins\ndtt\ndttGui.py:29
msgid "Off"
msgstr "Выключено"

#. Translators: This is a label of an item for the backup combo box in the NDTT Settings panel.
#: addon\globalPlugins\ndtt\ndttGui.py:31
msgid "On"
msgstr "Включено"

#. Translators: This is a label for an edit field in the NDTT Settings panel.
#: addon\globalPlugins\ndtt\ndttGui.py:39
#, python-brace-format
msgid "Command to open a file in your favorite editor\n"
"(use \"{path}\" and \"{line}\" placeholders in this command)"
msgstr "Команда для открытия файла в вашем любимом редакторе\n"
"(используйте заполнители \"{path}\" и \"{line}\" в этой команде)"

#. Translators: This is a label for an edit field in the NDTT Settings panel.
#: addon\globalPlugins\ndtt\ndttGui.py:46
msgid "NVDA source code path"
msgstr "Путь исходного кода NVDA"

#. Translators: The label of a button to browse for a directory or a file.
#: addon\globalPlugins\ndtt\ndttGui.py:52
#: addon\globalPlugins\ndtt\restartWithOptions.py:210
#: addon\globalPlugins\ndtt\restartWithOptions.py:234
msgid "Browse..."
msgstr "Обзор..."

#. Translators: The title of the dialog presented when browsing for the directory.
#: addon\globalPlugins\ndtt\ndttGui.py:54
#: addon\globalPlugins\ndtt\restartWithOptions.py:236
msgid "Select a directory"
msgstr "Выберите каталог"

#. Translators: This is a label for the combo box in the NDTT Settings panel.
#: addon\globalPlugins\ndtt\ndttGui.py:61
msgid "Backup of old logs:"
msgstr "Резервное копирование старых журналов:"

#. Translators: This is a label for a setting in the settings panel
#: addon\globalPlugins\ndtt\ndttGui.py:77
msgid "Limit the number of backups to:"
msgstr "Ограничить количество резервных копий до:"

#. Translators: Input help mode message for a command of the object property explorer.
#: addon\globalPlugins\ndtt\objPropExplorer.py:75
msgid "Reports the currently selected property of the object property explorer for the navigator object; two presses displays this information in a browseable message."
msgstr ""

#. Translators: Input help mode message for a command of the object property explorer.
#: addon\globalPlugins\ndtt\objPropExplorer.py:83
msgid "Selects the next property of the object property explorer and reports it for the navigator object."
msgstr "Выбирает следующее свойство проводника свойств объекта и сообщает его объекту навигатора."

#. Translators: Input help mode message for a command of the object property explorer.
#: addon\globalPlugins\ndtt\objPropExplorer.py:92
msgid "Selects the previous property of the object property explorer and reports it for the navigator object."
msgstr "Выбирает предыдущее свойство проводника свойств объекта и сообщает его объекту навигатора."

#. Translators: The title of a file selector window
#: addon\globalPlugins\ndtt\restartWithOptions.py:98
msgid "Save As"
msgstr "Сохранить как"

#. Translators: the label for the NVDA log extension (log) file type
#: addon\globalPlugins\ndtt\restartWithOptions.py:212
#, python-brace-format
msgid "NVDA log file (*.{ext})"
msgstr "Файл журнала NVDA (*.{ext})"

#. Translators: The title of the dialog presented when browsing for the file.
#: addon\globalPlugins\ndtt\restartWithOptions.py:214
msgid "Select a file"
msgstr "Выберите файл"

#. class RestartWithOptionsDialog(wx.):
#. Translators: This is the title for the Restart with options dialog
#: addon\globalPlugins\ndtt\restartWithOptions.py:247
msgid "Specify some options and restart"
msgstr "Укажите некоторые параметры и перезапустите"

#. Translators: The description of an NVDA start option, copied from the user guide (paragraph Command Line Options)
#: addon\globalPlugins\ndtt\restartWithOptions.py:272
msgid "The file where log messages should be written to"
msgstr "Файл, в который следует записывать сообщения журнала"

#. Translators: The description of an NVDA start option, copied from the user guide (paragraph Command Line Options)
#: addon\globalPlugins\ndtt\restartWithOptions.py:278
msgid "The lowest level of message logged"
msgstr "Самый низкий уровень зарегистрированных сообщений"

#. Translators: The description of an NVDA start option, copied from the user guide (paragraph Command Line Options)
#: addon\globalPlugins\ndtt\restartWithOptions.py:285
msgid "The path where all settings for NVDA are stored"
msgstr "Путь, по которому хранятся все настройки для NVDA"

#. Translators: The description of an NVDA start option, copied from the user guide (paragraph Command Line Options)
#: addon\globalPlugins\ndtt\restartWithOptions.py:291
msgid "Override the configured NVDA language"
msgstr "Переопределить настроенный язык NVDA"

#. Translators: The description of an NVDA start option, copied from the user guide (paragraph Command Line Options)
#: addon\globalPlugins\ndtt\restartWithOptions.py:298
msgid "No sounds, no interface, no start message, etc."
msgstr "Ни звуков, ни интерфейса, ни исходного сообщения и т. д."

#. Translators: The description of an NVDA start option, copied from the user guide (paragraph Command Line Options)
#: addon\globalPlugins\ndtt\restartWithOptions.py:304
msgid "Secure mode"
msgstr "Безопасный режим"

#. Translators: The description of an NVDA start option, copied from the user guide (paragraph Command Line Options)
#: addon\globalPlugins\ndtt\restartWithOptions.py:310
msgid "Add-ons will have no effect"
msgstr "Дополнения не окажут никакого влияния"

#. Translators: The description of an NVDA start option, copied from the user guide (paragraph Command Line Options)
#: addon\globalPlugins\ndtt\restartWithOptions.py:318
msgid "Don't change the global system screen reader flag"
msgstr "Не изменять флаг читателя экрана глобальной системы"

#. Translators: Input help mode message for Restart with options command.
#: addon\globalPlugins\ndtt\restartWithOptions.py:364
msgid "Restarts NVDA with specific options."
msgstr "Перезапускает NVDA с определёнными параметрами."

#. Translators: Input help mode message for a toggle command.
#: addon\globalPlugins\ndtt\stackTracing.py:50
msgid "Toggles the stack trace log when the speech function is called."
msgstr "Переключает журнал отслеживания стека при вызове языковой функции."

#. Translators: Reported when toggling the stack trace log feature.
#: addon\globalPlugins\ndtt\stackTracing.py:59
msgid "Stacktrace log enabled"
msgstr "Журнал отслеживания стека включён"

#. Translators: Reported when toggling the stack trace log feature.
#: addon\globalPlugins\ndtt\stackTracing.py:62
msgid "Stacktrace log disabled"
msgstr "Журнал отслеживания стека выключен"

#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on
#. to be shown on installation and add-on information found in Add-ons Manager.
#: buildVars.py:23
msgid "NVDA Dev & Test Toolbox"
msgstr "NVDA Dev & Test Toolbox"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:26
msgid "A set of tools for NVDA developers and testers."
msgstr "Набор инструментов для разработчиков и тестировщиков NVDA."

