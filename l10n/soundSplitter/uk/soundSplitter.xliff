        <note appliesTo="source">prefix: * </note>
      </notes>
      <segment state="initial">
        <source>Alt+NVDA+S: toggle sound splitter between enabled with NVDA on the right channel, NVDA on the left channel, or disabled.</source>
        <target>Alt+NVDA+S: toggle sound splitter between enabled with NVDA on the right channel, NVDA on the left channel, or disabled.</target>
      </segment>
