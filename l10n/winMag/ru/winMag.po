#. Alpha-numeric keyboard Magnifier keys
#. Translators: The key used natively byt the Magnifier on the alpha-numeric (main) keyboard in conjunction with Win key to zoom in.
#: addon\globalPlugins\winMag\__init__.py:63
msgid "="
msgstr "равно"

#. Translators: The key used natively byt the Magnifier on the alpha-numeric (main) keyboard in conjunction with Win key to zoom out.
#: addon\globalPlugins\winMag\__init__.py:65
msgid "-"
msgstr "минус"

#. Translators: The message reported when the user tries to use a Magnifier dedicated command while the Magnifier is not running.
#: addon\globalPlugins\winMag\__init__.py:155
msgid "The Magnifier is not active"
msgstr "Лупа не активна"

#. Translators: The message reported when the user tries to toggle a tracking mode while docked or full screen view is not active.
#: addon\globalPlugins\winMag\__init__.py:169
msgid "Tracking configuration only applicable with docked or full screen view."
msgstr "Конфигурация отслеживания применима только в закреплённом или полноэкранном режимах."

#. Translators: The description for the toggleCaretTracking script.
#: addon\globalPlugins\winMag\__init__.py:326
msgid "Toggles on or off caret tracking"
msgstr "Переключает отслеживание каретки"

#. Translators: The description for the toggleFocusTracking script.
#: addon\globalPlugins\winMag\__init__.py:328
msgid "Toggles on or off focus tracking"
msgstr "Переключает отслеживание фокуса"

#. Translators: The description for the toggleMouseTracking script.
#: addon\globalPlugins\winMag\__init__.py:330
msgid "Toggles on or off mouse tracking"
msgstr "Переключает отслеживание мыши"

#. Translators: The description for the toggleTracking script.
#: addon\globalPlugins\winMag\__init__.py:332
msgid "Toggles on or off tracking globally"
msgstr "Переключает глобальное отслеживание"

#. Translators: The description for the toggleSmoothing script.
#: addon\globalPlugins\winMag\__init__.py:334
msgid "Toggles on or off smoothing"
msgstr "Переключает сглаживание"

#. Translators: The description for the toggleMouseCursorTrackingMode script.
#: addon\globalPlugins\winMag\__init__.py:336
msgid "Switches between mouse tracking modes (within the edge of the screen or centered on the screen)"
msgstr ""

#. Translators: The description for the toggleTextCursorTrackingMode script.
#: addon\globalPlugins\winMag\__init__.py:338
msgid "Switches between text tracking modes (within the edge of the screen or centered on the screen)"
msgstr "Переключает между режимами отслеживания текста (по краям экрана или по центру экрана)"

#. Translators: The description for the moveMouseToView script.
#: addon\globalPlugins\winMag\__init__.py:340
msgid "Moves the mouse cursor in the center of the zoomed view"
msgstr "Перемещает курсор мыши в центр увеличенного представления"

#. Translators: The description for the openSettings script.
#: addon\globalPlugins\winMag\__init__.py:342
msgid "Opens Windows Magnifier add-on settings"
msgstr "Открывает настройки дополнения"

#. Translators: The description for the displayHelp script.
#: addon\globalPlugins\winMag\__init__.py:344
msgid "Displays help on Magnifier layer commands"
msgstr "Показывает справку по командам слоя лупы"

#. Translators: Part of the description for the layered command script.
#: addon\globalPlugins\winMag\__init__.py:392
msgid "Windows Magnifier layer commands entry point."
msgstr "Точка входа команд слоя лупы Windows."

#. Translators: A message reported when the user tries to execute script mouseToView
#: addon\globalPlugins\winMag\__init__.py:500
#: addon\globalPlugins\winMag\__init__.py:725
msgid "This command is not yet available in multi-screen environment. Please contact the add-on author to have it implemented."
msgstr ""

#. Translators: A dimension reported when the user resizes the docked view.
#: addon\globalPlugins\winMag\__init__.py:546
msgid "Widht"
msgstr "Ширина"

#. Translators: A dimension reported when the user resizes the docked view.
#: addon\globalPlugins\winMag\__init__.py:551
msgid "Height"
msgstr "Высота"

#. Translators: A message reported when the user resizes the lens with the keyboard.
#: addon\globalPlugins\winMag\__init__.py:557
msgid "Resizing lens."
msgstr "Изменение размера объектива."

#. Translators: A message reported when the user uses resizing shortcuts (control+shift+arrow) in full screen view.
#: addon\globalPlugins\winMag\__init__.py:560
msgid "Resizing not available in full screen."
msgstr "Изменение размера недоступно в полноэкранном режиме."

#. Translators: The message reported when the user turns on caret tracking.
#: addon\globalPlugins\winMag\__init__.py:576
msgid "Caret tracking on"
msgstr "Отслеживание каретки включено"

#. Translators: The message reported when the user turns off caret tracking.
#: addon\globalPlugins\winMag\__init__.py:579
msgid "Caret tracking off"
msgstr "Отслеживание каретки выключено"

#. Translators: The message reported when the user turns on focus tracking.
#: addon\globalPlugins\winMag\__init__.py:593
msgid "Focus tracking on"
msgstr "Отслеживание фокуса включено"

#. Translators: The message reported when the user turns off focus tracking.
#: addon\globalPlugins\winMag\__init__.py:596
msgid "Focus tracking off"
msgstr "Отслеживание фокуса выключено"

#. Translators: The message reported when the user turns on mouse tracking.
#: addon\globalPlugins\winMag\__init__.py:610
msgid "Mouse tracking on"
msgstr "Отслеживание мыши включено"

#. Translators: The message reported when the user turns off focus tracking.
#: addon\globalPlugins\winMag\__init__.py:613
msgid "Mouse tracking off"
msgstr "Отслеживание мыши выключено"

#. Translators: The message reported when the user turns on tracking.
#: addon\globalPlugins\winMag\__init__.py:626
msgid "Tracking on"
msgstr ""

#. Translators: The message reported when the user turns off tracking.
#: addon\globalPlugins\winMag\__init__.py:629
msgid "Tracking off"
msgstr "Отслеживание выключено"

#. Translators: The message reported when the user turns on smoothing.
#: addon\globalPlugins\winMag\__init__.py:641
msgid "Smoothing on"
msgstr "Сглаживание включено"

#. Translators: The message reported when the user turns off smoothing.
#: addon\globalPlugins\winMag\__init__.py:644
msgid "Smoothing off"
msgstr "Сглаживание выключено"

#. Translators: The message reported when the user tries to toggle mouse tracking mode whereas his Windows version does not support it.
#: addon\globalPlugins\winMag\__init__.py:656
#: addon\globalPlugins\winMag\__init__.py:681
msgid "Feature unavailable in this version of Windows."
msgstr "Функция недоступна в этой версии Windows."

#. Translators: The message reported when the user tries to toggle mouse tracking mode while full screen view is not active.
#: addon\globalPlugins\winMag\__init__.py:661
#: addon\globalPlugins\winMag\__init__.py:686
msgid "Mouse tracking mode applies only to full screen view."
msgstr ""

#. Translators: A message reporting mouse cursor tracking mode (cf. option in Magnifier settings).
#: addon\globalPlugins\winMag\__init__.py:666
#: addon\globalPlugins\winMag\__init__.py:691
msgid "Centered on the screen"
msgstr "По центру экрана"

#. Translators: A message reporting mouse cursor tracking mode (cf. option in Magnifier settings).
#: addon\globalPlugins\winMag\__init__.py:669
#: addon\globalPlugins\winMag\__init__.py:694
msgid "Within the edge of the screen"
msgstr "В пределах границы экрана"

#. Translators: A message reported when the user tries to execute script mouseToView
#: addon\globalPlugins\winMag\__init__.py:703
msgid "Move mouse to view command available only on Windows 8 and above."
msgstr ""

#. Translators: A message reported when the user tries to execute script mouseToView
#: addon\globalPlugins\winMag\__init__.py:708
msgid "Move mouse to view not applicable with lense view."
msgstr ""

#. o = getDockedWindowObject()
#. hwnd = o.windowHandle
#. # Error on next line
#. rect = Magnification.MagGetWindowSource(hwnd)
#. Translators: A message reported when the user tries to execute script mouseToView
#: addon\globalPlugins\winMag\__init__.py:720
msgid "Move mouse to view not implemented for docked view"
msgstr "Команда перемещения мыши на представление не реализована для закреплённого представления"

#. Translators: A message reported in secure screen when the user attempts to modify magnifiers settings.
#: addon\globalPlugins\winMag\__init__.py:738
msgid "Command unavailable on this screen."
msgstr "Команда недоступна на этом экране."

#. Translators: The message reported when the user turns on the Magnifier.
#: addon\globalPlugins\winMag\__init__.py:754
msgid "Magnifier on"
msgstr "Лупа включена"

#. Translators: The message reported when the user turns off the Magnifier.
#: addon\globalPlugins\winMag\__init__.py:757
msgid "Magnifier off"
msgstr "Лупа отключена"

#. Translators: A zoom level reported when the user changes the zoom level.
#: addon\globalPlugins\winMag\__init__.py:768
#, python-brace-format
msgid "{zoomLevel}%"
msgstr "{zoomLevel}%"

#. Translators: The message reported when the user turns on color inversion.
#: addon\globalPlugins\winMag\__init__.py:775
msgid "Color inversion on"
msgstr "Инверсия цвета включена"

#. Translators: The message reported when the user turns off color inversion.
#: addon\globalPlugins\winMag\__init__.py:778
msgid "Color inversion off"
msgstr "Инверсия цвета выключена"

#. Translators: A view type reported when the user changes the Magnifier view. See the view menu items in the Magnifier's toolbar.
#: addon\globalPlugins\winMag\__init__.py:787
msgid "Docked"
msgstr "Закреплено"

#. Translators: A view type reported when the user changes the Magnifier view. See the view menu items in the Magnifier's toolbar.
#: addon\globalPlugins\winMag\__init__.py:790
msgid "Full screen"
msgstr "Полноэкранный режим"

#. Translators: A view type reported when the user changes the Magnifier view. See the view menu items in the Magnifier's toolbar.
#: addon\globalPlugins\winMag\__init__.py:793
msgid "Lens"
msgstr "Объектив"

#. Translators: Title of the layered command help window.
#: addon\globalPlugins\winMag\__init__.py:808
msgid "Windows Magnifier layered commands"
msgstr "Многослойные команды Лупы Windows"

#. Translators: Part of the help message displayed for the layered command help.
#: addon\globalPlugins\winMag\__init__.py:811
#, python-brace-format
msgid "Magnifier layer commands:\n"
"{cmdList}"
msgstr "Команды слоя лупы:\n"
"{cmdList}"

#. Translators: This is the label for the Windows Magnifier settings panel.
#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on to be shown on installation and add-on information.
#: addon\globalPlugins\winMag\wmGui.py:26 buildVars.py:17
msgid "Windows Magnifier"
msgstr "Лупа Windows"

#. Translators: An option in the combobox "Report view moves" in winMag setting panel.
#: addon\globalPlugins\winMag\wmGui.py:30
msgid "Off"
msgstr "Выключено"

#. Translators: An option in the combobox "Report view moves" in winMag setting panel.
#: addon\globalPlugins\winMag\wmGui.py:32
msgid "With speech"
msgstr "Речь"

#. Translators: An option in the combobox "Report view moves" in winMag setting panel.
#: addon\globalPlugins\winMag\wmGui.py:34
msgid "With tones"
msgstr "Сигналы"

#. Translators: An option in the combobox that configures passing control+alt+arrow in winMag setting panel.
#: addon\globalPlugins\winMag\wmGui.py:38
msgid "Never"
msgstr "Никогда"

#. Translators: An option in the combobox that configures passing control+alt+arrow in winMag setting panel.
#: addon\globalPlugins\winMag\wmGui.py:40
msgid "Only when not in table"
msgstr "Только когда не в таблице"

#. Translators: An option in the combobox that configures passing control+alt+arrow in winMag setting panel.
#: addon\globalPlugins\winMag\wmGui.py:42
msgid "Always"
msgstr "Всегда"

#. Translators: This is the label for a combobox in the Windows Magnifier settings panel.
#: addon\globalPlugins\winMag\wmGui.py:49
msgid "Report view &moves:"
msgstr "Сообщать о &перемещениях представления:"

#. Translators: This is the label for a checkbox in the Windows Magnifier settings panel.
#: addon\globalPlugins\winMag\wmGui.py:63
msgid "Report &turn on or off"
msgstr "&Сообщать о включении или выключении"

#. Translators: This is the label for a checkbox in the Windows Magnifier settings panel.
#: addon\globalPlugins\winMag\wmGui.py:69
msgid "Report &zoom"
msgstr "Сообщать об &увеличении"

#. Translators: This is the label for a checkbox in the Windows Magnifier settings panel.
#: addon\globalPlugins\winMag\wmGui.py:75
msgid "Report color &inversion"
msgstr "Сообщать об инверсии &цвета"

#. Translators: This is the label for a checkbox in the Windows Magnifier settings panel.
#: addon\globalPlugins\winMag\wmGui.py:81
msgid "Report &view change"
msgstr "Сообщать об изменении &представления"

#. Translators: This is the label for a checkbox in the Windows Magnifier settings panel.
#: addon\globalPlugins\winMag\wmGui.py:87
msgid "Report &lens or docked window resizing"
msgstr "&Сообщать изменение размера объектива или закреплённого окна"

#. Translators: This is the label for a combobox in the Windows Magnifier settings panel.
#: addon\globalPlugins\winMag\wmGui.py:92
msgid "In &documents and list views, pass control+alt+arrows shortcuts to Windows Magnifier:"
msgstr "Передавать сочетания клавиш control+alt+стрелки в Windows Magnifier в &документах и списках:"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:20
msgid "This addon improves the use of Windows Magnifier with NVDA with the following features:\n"
"\t- Allows to report the result of some native Magnifier keyboard commands.\n"
"\t- Allows to reduces the cases where table navigation command conflict with Magnifier's commands.\n"
"\t- Adds some keyboard shortcuts to toggle various Magnifier options."
msgstr ""

