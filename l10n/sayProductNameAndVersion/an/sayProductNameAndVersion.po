#. Translators: Input help mode message for say product name and version command.
#: addon\globalPlugins\sayProductNameAndVersion.py:32
msgid "Speaks the product name and version of the application which ownes the focused window. If pressed twice, copies this information to the clipboard"
msgstr ""

#. Translators: This is used when the name of the focused application cannot be found.
#: addon\globalPlugins\sayProductNameAndVersion.py:49
msgid "Application"
msgstr ""

#. Translators: This is the message which will be spoken or copied to the clipboard.
#. {name} is the app name, {version} is the version.
#: addon\globalPlugins\sayProductNameAndVersion.py:55
#: addon\globalPlugins\sayProductNameAndVersion.py:57
#, python-brace-format
msgid "{name} version {version}"
msgstr ""

#. Translators: This is the message announced when all information has been copied.
#: addon\globalPlugins\sayProductNameAndVersion.py:59
#, python-brace-format
msgid "{name} version {version} copied to the clipboard"
msgstr ""

#. Translators: This is the message announced when all information hasn't been copied.
#: addon\globalPlugins\sayProductNameAndVersion.py:64
msgid "Cannot copy version information to the clipboard."
msgstr ""

#. Translators: this will be spoken if version information was not available.
#: addon\globalPlugins\sayProductNameAndVersion.py:67
msgid "Unable to get version info"
msgstr ""

#. Add-on summary
#. Translators: Summary for this add-on to be shown on installation and add-on information.
#: buildVars.py:21
msgid "Say Product Name and Version"
msgstr ""

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-ons manager
#: buildVars.py:24
msgid "Say product name and version of the application which ownes the focused window.\n"
"Default shortcut: Shift+NVDA+V"
msgstr ""

