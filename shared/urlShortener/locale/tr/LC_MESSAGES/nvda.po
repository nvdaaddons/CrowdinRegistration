#: addon\globalPlugins\urlShortener\urlsGui.py:144
msgid "Remove &saved URLs..."
msgstr "Kayıtlı URL'leri kaldı&r..."

#. Translators: Message presented when a shortened URL cannot be added.
#: addon\globalPlugins\urlShortener\urlsGui.py:175
#, python-format
msgid "Cannot add URL: %s"
msgstr "URL eklenemiyor: %s"

#. Translators: Error message.
#: addon\globalPlugins\urlShortener\urlsGui.py:177
msgid "Error"
