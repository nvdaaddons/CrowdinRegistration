#: addon\globalPlugins\urlShortener\__init__.py:54
msgid "Activates the Shorten URL dialog."
msgstr "URL Kısaltıcı iletişim kutusunu etkinleştirir."

#. Translators: The title of a dialog.
#: addon\globalPlugins\urlShortener\urlsGui.py:37
msgid "&Rename URL"
msgstr ""

#. Translators: The label of a field to enter an address for a new shortened URL.
#: addon\globalPlugins\urlShortener\urlsGui.py:45
msgid "&URL"
msgstr ""

#. Translators: The label of a field to enter the name for a new URL.
#: addon\globalPlugins\urlShortener\urlsGui.py:49
msgid "&Name"
msgstr ""

#. Translators: The title of a dialog.
#: addon\globalPlugins\urlShortener\urlsGui.py:92
msgid "urls"
msgstr "url'ler"

