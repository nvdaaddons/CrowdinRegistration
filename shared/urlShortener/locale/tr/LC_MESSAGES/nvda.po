#. Translators: The title of a dialog.
#: addon\globalPlugins\urlShortener\urlsGui.py:217
msgid "Shorten URL"
msgstr ""

#. Translators: The confirmation prompt displayed when the user requests to delete an URL.
#: addon\globalPlugins\urlShortener\urlsGui.py:253
#, python-format
msgid "Are you sure you want to delete this URL: %s?"
msgstr "Bu URL'yi silmek istediğinizden emin misiniz: %s?"

#. Translators: The label of a field to enter a new name for an URL.
#: addon\globalPlugins\urlShortener\urlsGui.py:284
