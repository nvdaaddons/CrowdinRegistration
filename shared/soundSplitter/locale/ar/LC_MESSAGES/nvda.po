#. Translators: title of the error dialog shown when trying to install the add-on in unsupported systems.
#. Unsupported systems include Windows versions earlier than 10 and unsupported feature updates.
#: addon\installTasks.py:23
msgid "Unsupported Windows release"
msgstr ""

#. Translators: Dialog text shown when trying to install the add-on on
#. releases earlier than minimum supported release.
#: addon\installTasks.py:31
#, python-brace-format
msgid "You are using {releaseName} ({build}), a Windows release not supported by this add-on.\n"
"This add-on requires {supportedReleaseName} ({supportedBuild}) or later."
msgstr ""

#. Translators: Title for the settings dialog
#. Add-on summary, usually the user visible name of the addon.
#. Translators: Summary for this add-on
#. to be shown on installation and add-on information found in Add-ons Manager.
#: addon\globalPlugins\soundSplitter\__init__.py:69
#: addon\globalPlugins\soundSplitter\__init__.py:231 buildVars.py:23
msgid "Sound Splitter"
msgstr ""

#. Translators: a message shown in the configuration panel, when WASAPI is enabled in NVDA
#: addon\globalPlugins\soundSplitter\__init__.py:73
msgid "The Sound Splitter add-on can not currently be used in this version of NVDA while WASAPI is enabled in NVDA Advanced settings.\n"
"If you want to use Sound Splitter, first disable WASAPI, then restart NVDA.\n"
"The author apologizes for this inconvenience, and intends to support WASAPI as soon as possible."
msgstr ""

#. checkbox Enable sound split
#. Translators: Checkbox for sound split
#: addon\globalPlugins\soundSplitter\__init__.py:90
msgid "&Split NVDA sound and applications' sounds into left and right channels"
msgstr ""

#. checkbox switch left and right during sound split
#. Translators: Checkbox for switching left and right sound split
#: addon\globalPlugins\soundSplitter\__init__.py:95
msgid "Switch &left and right during sound split"
msgstr ""

#. Translators: Spoken if WASAPI is in use, and the user tries to use the add-on.
#: addon\globalPlugins\soundSplitter\__init__.py:223
msgid "Sound Splitter is disabled while WASAPI is being used. Please Turn off WASAPI in NVDA Advanced settings, restart NVDA and try again."
msgstr ""

#. Translators: input help message for toggle sound splitter command.
#: addon\globalPlugins\soundSplitter\__init__.py:261
msgid "Toggle sound split"
msgstr ""

#. Translators: presented when toggling sound splitter.
#: addon\globalPlugins\soundSplitter\__init__.py:274
msgid "Sound split enabled, NVDA on the right"
msgstr ""

#. Translators: presented when toggling sound splitter.
#: addon\globalPlugins\soundSplitter\__init__.py:278
msgid "Sound split enabled, NVDA on the left"
msgstr ""

#. Translators: presented when toggling sound splitter.
#: addon\globalPlugins\soundSplitter\__init__.py:283
msgid "Sound split disabled"
msgstr ""

