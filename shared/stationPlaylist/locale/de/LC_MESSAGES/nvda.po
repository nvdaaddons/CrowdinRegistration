#: addon/appModules/remotestudio.py:184
#: addon/appModules/splstudio/__init__.py:915
#: addon/appModules/splstudio/__init__.py:1480
msgid "Some or all carts could not be assigned, cannot enter cart explorer"
msgstr "Einige oder alle Carts konnten nicht zugewiesen werden. Daher konnte der Cart-Explorer nicht aufgerufen werden"

