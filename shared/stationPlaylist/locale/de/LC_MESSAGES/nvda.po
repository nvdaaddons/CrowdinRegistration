#. Translators: Input help mode message for a command in StationPlaylist add-on.
#: addon/appModules/tracktool.py:200 addon/appModules/splcreator.py:288
#: addon/appModules/splstudio/__init__.py:1227
msgid "Opens SPL Studio add-on configuration dialog."
msgstr "Öffnet die Einstellungen zur Erweiterung von SPL Studio."

#. Translators: announced in SPL Creator and Remote VT
#. when trying to perform playlist status commands while outside of playlist editor.
#: addon/appModules/splcreator.py:343
msgid "You are not in playlist editor"
msgstr "Sie befinden sich nicht im Playlist-Editor"

#. Translators: Presented when cart modes are toggled while cart explorer is on.
#: addon/appModules/remotestudio.py:112
#: addon/appModules/splstudio/__init__.py:960
msgid "Cart explorer is active"
msgstr "Cart-Übersicht aktiviert"

