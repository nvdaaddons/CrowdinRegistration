#: addon/appModules/remotestudio.py:195
#: addon/appModules/splstudio/__init__.py:1493
msgid "Exiting cart explorer"
msgstr "Cart-Übersicht wird beendet"

#. Translators: title of a dialog to configure broadcast profiles.
#: addon/appModules/splcommon/splconfui.py:43
#: addon/appModules/splcommon/splconfui.py:1781
msgid "SPL Broadcast Profiles"
msgstr "SPL-Broadcast-Profile"

#. Borrowed directly from NVDA Core (credit: NV Access)
#. This allows Enter key to be pressed to activate the selected profile.
#. Translators: label for a button to activate the selected broadcast profile.
#: addon/appModules/splcommon/splconfui.py:71
msgid "Activate"
msgstr "Aktivieren"

#. Translators: The label of a button to copy a broadcast profile.
#: addon/appModules/splcommon/splconfui.py:87
msgid "Cop&y"
msgstr "&Kopieren"

#. Translators: Message reported when attempting to delete a profile in the midst of a broadcast.
#: addon/appModules/splcommon/splconfui.py:202
msgid "An instant switch profile might be active or you are in the midst of a broadcast. If so, please press SPL Assistant, F12 to switch back to a previously active profile before opening broadcast profiles dialog to delete a profile."
msgstr "Möglicherweise ist ein Profil für den Sofortwechsel aktiv oder Sie befinden sich mitten in einer Sendung. In diesem Fall drücken Sie bitte die F12-Taste für den SPL-Assistenten, um zu einem zuvor aktiven Profil zurückzukehren, bevor Sie die Zusatzeinstellungen zum Löschen eines Profils öffnen."

#. Translators: Title of a dialog shown when profile cannot be deleted.
#: addon/appModules/splcommon/splconfui.py:207
msgid "Profile delete error"
msgstr "Fehler beim Löschen des Profils"

#: addon/appModules/splcommon/splconfui.py:220
msgid "You are about to delete the currently active profile. Select yes if you wish to proceed."
msgstr "Sie sind dabei, das gerade aktive Profil zu löschen. Wählen Sie Ja, wenn Sie fortfahren möchten."

#. Translators: The title of the confirmation dialog for deletion of a profile.
#: addon/appModules/splcommon/splconfui.py:223
